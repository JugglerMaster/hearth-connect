# Hearth-Connect Pi Agent configuration
# Copy this file to /opt/hearth-pi-agent/config.env and edit for your setup.

SERVER_URL=wss://your-server-host:8090
ROOM_ID=default
DEVICE_LABEL=Pi Agent

# Leave blank to auto-pick the first available device.
# Otherwise set to a V4L2 path (e.g. /dev/video0) or ALSA id (e.g. hw:1,0).
VIDEO_DEVICE=
AUDIO_DEVICE=

# Resolution / framerate can also be changed live from the base station
# (camera config) — the agent rewrites these values here on change so they
# persist across restarts.
RESOLUTION=720p
FRAMERATE=24

# ─── Talkback / broadcast receive (headless audio output) ───
# The Pi is a kiosk-type client: it receives the base station's two-way talkback
# audio AND "Broadcast Message" announcements / FaceTalk video+audio. To hear
# them, attach a speaker/headphone. Leave blank to use the default ALSA device.
SPEAKER_DEVICE=
# Or override the full ALSA sink (e.g. 'alsasink device=hw:0,0'). Takes
# precedence over SPEAKER_DEVICE.
AUDIO_SINK=

# ─── 1GB-Pi resource guard ───
# Max simultaneous viewer (monitor) peer connections. Each viewer gets its own
# GStreamer pipeline. Keep low on 1GB Pis (real RAM ~700-900MB free after GPU
# split). Default 4.
MAX_SUBSCRIBERS=4
