server/node_modules/

# Self-signed TLS certs are generated per deployment (deploy/gen-cert.sh) and
# must never be committed — they contain private keys (ca.key) and are unique
# per host/LAN. The server also regenerates them on launch if missing.
server/certs/
deploy/certs/

# Runtime state (per-deployment device/room config) + scratch notes.
data/
server/data/config.json
updates.txt

# Python bytecode (pi-agent + tooling)
__pycache__/
*.pyc

# Android runtime-generated TLS keystore (created by SignalingServer on first launch)
android/app/src/main/assets/keystore/

# Pi agent bytecode
linux/pi-agent/__pycache__/

# Android build artifacts
android/.gradle/
android/app/build/
